# ─────────────────────────────────────────────────────────────────────────────
# LJ Workflow Creator — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
#
# 1. Go to https://supabase.com and create a new project.
# 2. In your project dashboard: Settings → Database → Connection string
# 3. Copy the "Transaction" URI  →  DATABASE_URL  (used by Prisma at runtime via PgBouncer)
# 4. Copy the "Direct" URI       →  DIRECT_URL    (used by Prisma Migrate)
#
# Both strings look like:
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[HOST]:PORT/postgres
#
# For DATABASE_URL (Transaction / PgBouncer), append: ?pgbouncer=true&connection_limit=1

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Supabase JS Client ────────────────────────────────────────────────────────
#
# Found in: Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL    — your project URL (safe to expose, prefix keeps it in the browser bundle)
# NEXT_PUBLIC_SUPABASE_ANON_KEY — public anon key (safe to expose, RLS is your guard)
# SUPABASE_SERVICE_ROLE_KEY   — secret service role key (NEVER expose client-side, bypasses RLS)

NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Landjourney platform (demo bridge — all optional) ────────────────────────
#
# When set, the Workflow Creator pickers sync live building blocks (users,
# retailers, request-template stages, forms) from the real admin API instead
# of the static demo vocabulary. Server-side only — never exposed to the
# browser. Leave unset to run fully static.
#
# ⚠ Known blocker (build manual §12 Q2): a bare bearer returns HTTP 500 — the
# product's HTTP interceptor adds more (tenant header / decompressed token).
# Once Antigravity confirms the missing headers in source, supply them as JSON
# via LANDJOURNEY_EXTRA_HEADERS, e.g. {"x-organization-id":"<uuid>"}.

LANDJOURNEY_API_BASE="https://api-test.landjourney.ai"
LANDJOURNEY_API_TOKEN=""
LANDJOURNEY_ORG_ID="1577b554-df12-4dca-8430-cf307ab39389"
LANDJOURNEY_EXTRA_HEADERS=""

# ── Novu (action executor: `notify`) ─────────────────────────────────────────
#
# The /api/execute route sends real in-app notifications through Novu when
# configured (the admin's inbox is already Novu-wired). Without a key the
# executor honestly reports not-configured instead of faking success.

NOVU_API_KEY=""
NOVU_WORKFLOW_ID="workflow-notify"
