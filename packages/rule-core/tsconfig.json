{
  // WALL: no 'dom' lib and no ambient types. JSX, document, window, and
  // framework globals fail to compile here on purpose. Do not add 'dom' or
  // 'react' to this file.
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": [],
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
