generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workflow {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  enabled     Boolean  @default(true)
  ruleJson    Json     @map("rule_json")
  version     Int      @default(1) // Phase 8 §12 — optimistic concurrency guard
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  executions RuleExecution[]
  proposals  WorkflowProposal[]

  @@map("workflows")
}

model WorkflowProposal {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  workflowId      String   @map("workflow_id")
  proposedRule    Json     @map("proposed_rule")
  proposedEnabled Boolean? @map("proposed_enabled")
  proposerId      String   @map("proposer_id")
  status          String
  taskId          String?  @map("task_id")
  createdAt       DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([orgId, workflowId])
  @@map("workflow_proposals")
}

model RuleExecution {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  workflowId        String   @map("workflow_id")
  requestId         String   @map("request_id")
  requestName       String   @map("request_name")
  eventName         String   @map("event_name")
  status            String // "FIRED" | "CONDITIONS_NOT_MET" | "ERROR" | "SHADOW" | "PAUSED_ORG" | "SKIPPED_DUPLICATE" | "PAUSED_RATE_LIMIT" | "OVERRIDDEN"
  mode              String   @default("shadow") // "shadow" | "armed" — enforcement mode at fire time
  evaluationTrace   Json     @map("evaluation_trace")
  actionsDispatched Json     @map("actions_dispatched")
  createdAt         DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([orgId, requestId])
  @@map("rule_executions")
}

model WorkflowOrgControls {
  orgId             String   @id @map("org_id")
  automationsPaused Boolean  @default(false) @map("automations_paused")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("workflow_org_controls")
}

model ApprovalAuthority {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  name         String
  limit        Decimal  @db.Decimal(12, 2)
  riskGrade    String   @map("risk_grade") // Minimum risk grade, e.g. "A", "B", "C", "D", "E"
  product      String   @map("product") // "Term Loan" | "Line of Credit" | "All"
  userIds      Json     @map("user_ids") // JSON array of user names/IDs assigned
  requirement  Json?    @map("requirement") // ApprovalRequirement topology (quorum/sequence); null → legacy any-of userIds
  escalationId String?  @map("escalation_id")
  autoApprove  Boolean  @default(false) @map("auto_approve")
  overageTolerancePercent Float? @default(0) @map("overage_tolerance_percent")
  overageToleranceAmount  Float? @default(0) @map("overage_tolerance_amount")
  version      Int      @default(1) // Phase 8 §12 — optimistic concurrency guard
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  escalation  ApprovalAuthority?  @relation("EscalationRelation", fields: [escalationId], references: [id], onDelete: SetNull)
  escalatedBy ApprovalAuthority[] @relation("EscalationRelation")
  tasks       ApprovalTask[]

  @@map("approval_authorities")
}

model Delegation {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  scope      String
  startsAt   DateTime @map("starts_at")
  endsAt     DateTime @map("ends_at")
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([orgId, fromUserId])
  @@map("delegations")
}

model ApprovalTask {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  authorityId String   @map("authority_id")
  requestId   String   @map("request_id")
  requirement Json // envelope: { requirement: ApprovalRequirement, exclusions: string[] }
  status      String // "open" | "approved" | "declined" | "expired"
  createdAt   DateTime @default(now()) @map("created_at")

  decisions ApprovalDecision[]
  authority ApprovalAuthority  @relation(fields: [authorityId], references: [id], onDelete: Cascade)

  @@index([orgId, requestId])
  @@map("approval_tasks")
}

model ApprovalDecision {
  id            String   @id @default(uuid())
  taskId        String   @map("task_id")
  approverId    String   @map("approver_id")
  approverLabel String   @map("approver_label")
  verdict       String // "approve" | "decline" | "abstain"
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  task ApprovalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, approverId])
  @@map("approval_decisions")
}

model Customer {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  type         String
  name         String
  status       String   @default("active") // "active" | "merged" | "archived"
  mergedIntoId String?  @map("merged_into_id")
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  mergedInto   Customer?          @relation("CustomerMergeAlias", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Customer[]         @relation("CustomerMergeAlias")
  fromRels     CustomerRelationship[] @relation("CustomerRelationshipFrom")
  toRels       CustomerRelationship[] @relation("CustomerRelationshipTo")
  requestRoles  RequestCustomerRole[]

  @@unique([orgId, name])
  @@index([orgId, mergedIntoId])
  @@map("customers")
}

model CustomerRelationship {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  fromId       String   @map("from_id")
  toId         String   @map("to_id")
  relationType String   @map("relation_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  from Customer @relation("CustomerRelationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Customer @relation("CustomerRelationshipTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([orgId, fromId])
  @@index([orgId, toId])
  @@map("customer_relationships")
}

model RequestCustomerRole {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  requestId  String   @map("request_id")
  customerId String   @map("customer_id")
  role       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([requestId, customerId, role])
  @@index([orgId, customerId])
  @@index([orgId, requestId])
  @@map("request_customer_roles")
}

// Append-only lifecycle log (edge-cases doc §13). Core emits CUSTOMERS_MERGED;
// other `type` values are reserved for later phases. History is immutable — rows
// are never updated or deleted (principle A).
model PlatformAuditLog {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  type        String // CUSTOMERS_MERGED (core) | REQUEST_REOPENED | USER_REASSIGNED | ...
  subjectType String   @map("subject_type") // "customer" | "workflow" | "authority" | "request"
  subjectId   String   @map("subject_id")
  payload     Json
  actorId     String   @map("actor_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orgId, subjectType, subjectId])
  @@index([orgId, type, createdAt])
  @@map("platform_audit_log")
}

// Phase 8 §11 — per-sink circuit-breaker state (table-backed: serverless cold
// starts reset in-memory state). statusJson holds lib/circuitBreaker BreakerState.
model SinkHealth {
  orgId      String   @map("org_id")
  sink       String // "novu" | "platform-bridge" | future write endpoints
  statusJson Json     @map("status_json")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@id([orgId, sink])
  @@map("sink_health")
}

// Phase 8 §3 — prototype-owned many-to-many index: one canonical document
// (owned by the admin documents service — UNCONFIRMED linkage support there)
// satisfying several requests' checklists. Not a second source of truth.
model DocumentLink {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  documentId String    @map("document_id") // canonical id — from the documents service
  requestId  String    @map("request_id")
  purpose    String? // e.g. "renewal-2026", "covenant-q1-2026"
  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until") // expiry — drives the refresh check
  linkedAt   DateTime  @default(now()) @map("linked_at")
  linkedBy   String    @map("linked_by") // userId

  @@unique([documentId, requestId])
  @@index([orgId, requestId])
  @@index([orgId, documentId])
  @@map("document_links")
}

// Phase 8 §7 — scheduled-action data model ONLY (the scheduler stays deferred:
// no worker/cron exists in this serverless prototype). runAt is a cache, always
// derived from anchorField's current value + offsetMinutes — see lib/scheduledActions.ts.
model ScheduledAction {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  workflowId    String   @map("workflow_id")
  requestId     String   @map("request_id")
  actionIndex   Int      @map("action_index") // index into rule.actions[]
  anchorField   String   @map("anchor_field") // ConditionFieldRef key, e.g. "maturity_date"
  offsetMinutes Int      @map("offset_minutes") // negative = before anchor
  runAt         DateTime @map("run_at")
  status        String   @default("pending") // "pending" | "fired" | "canceled" | "superseded"
  supersedes    String?  @map("supersedes") // principle A: prior ScheduledAction.id
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([orgId, status, runAt])
  @@index([orgId, requestId, anchorField])
  @@map("scheduled_actions")
}
