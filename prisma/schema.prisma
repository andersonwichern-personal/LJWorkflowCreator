generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PriceRange {
  id        String   @id @default(cuid())
  category  String   @unique
  low       Float
  high      Float
  unit      String
  notes     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]

  @@map("price_ranges")
}

model Quote {
  id                String     @id @default(cuid())
  contractor        String
  amount            Float
  category          String
  verdict           String     // "great" | "fair" | "high" | "very_high"
  message           String
  percentOfMidpoint Int
  priceRange        PriceRange @relation(fields: [category], references: [category])
  createdAt         DateTime   @default(now())

  @@map("quotes")
}
